<Window x:Class="Shutter.App.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shutter — Recording History"
        Background="#1a1a1a"
        Foreground="White"
        MinWidth="640" MinHeight="300"
        ShowInTaskbar="True">

    <Window.Resources>
        <!-- DataGrid chrome -->
        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#252525"/>
            <Setter Property="Foreground"   Value="#aaaaaa"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="10,6"/>
            <Setter Property="BorderBrush"  Value="#333"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="CellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="10,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0078D4"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RowStyle" TargetType="DataGridRow">
            <Setter Property="Background"        Value="#1a1a1a"/>
            <Setter Property="Foreground"        Value="#e0e0e0"/>
            <Setter Property="Height"            Value="36"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2e2e2e"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#004a8f"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Row context menu -->
        <ContextMenu x:Key="RowMenu">
            <MenuItem Header="Copy Path"           Click="CopyPath_Click"/>
            <MenuItem Header="Open File"           Click="OpenFile_Click"/>
            <MenuItem Header="Open in Explorer"    Click="OpenInExplorer_Click"/>
            <Separator/>
            <MenuItem Header="Remove from History" Click="RemoveEntry_Click"/>
        </ContextMenu>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- header bar -->
            <RowDefinition Height="*"/>    <!-- grid -->
            <RowDefinition Height="Auto"/> <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="#252525" Padding="16,12">
            <Grid>
                <TextBlock Text="Recording History"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
                <TextBlock x:Name="CountText"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="#666" FontSize="12"/>
            </Grid>
        </Border>

        <!-- ── Data grid ── -->
        <DataGrid x:Name="HistoryGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeRows="False"
                  CanUserReorderColumns="False"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#2a2a2a"
                  RowDetailsVisibilityMode="Collapsed"
                  AlternationCount="2"
                  SelectionMode="Single"
                  ColumnHeaderStyle="{StaticResource HeaderStyle}"
                  CellStyle="{StaticResource CellStyle}"
                  RowStyle="{StaticResource RowStyle}"
                  RowHeaderWidth="0"
                  Background="#1a1a1a"
                  BorderThickness="0"
                  ContextMenu="{StaticResource RowMenu}"
                  MouseLeftButtonUp="Grid_MouseLeftButtonUp"
                  MouseDoubleClick="Grid_MouseDoubleClick">
            <DataGrid.Columns>
                <!-- Status: ⚠ silent  |  ✕ missing -->
                <DataGridTemplateColumn Header="" Width="32" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusGlyph}"
                                       ToolTip="{Binding StatusTooltip}"
                                       HorizontalAlignment="Center"
                                       Foreground="{Binding StatusColor}"
                                       FontSize="13"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Recorded"  Binding="{Binding FormattedDate}"  Width="140"/>
                <DataGridTextColumn Header="Duration"  Binding="{Binding Duration}"       Width="80"/>
                <DataGridTextColumn Header="Size"      Binding="{Binding FormattedSize}"  Width="80"/>
                <DataGridTextColumn Header="File name" Binding="{Binding FileName}"       Width="220"/>

                <!-- Path — dimmed if missing -->
                <DataGridTemplateColumn Header="Path" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path}"
                                       Opacity="{Binding PathOpacity}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Path}"
                                       FontFamily="Consolas"
                                       FontSize="11"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" Grid.Row="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="Collapsed">
            <TextBlock Text="🎙" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="No recordings yet." Foreground="#666"
                       FontSize="14" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ── Status bar ── -->
        <Border Grid.Row="2" Background="#141414" Padding="16,6">
            <TextBlock x:Name="StatusText" Foreground="#555" FontSize="11"
                       Text="Click a row to copy path · Double-click to open · Right-click for more options"/>
        </Border>
    </Grid>
</Window>
