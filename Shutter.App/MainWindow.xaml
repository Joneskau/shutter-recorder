<Window x:Class="Shutter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shutter Settings" Height="390" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#131A26"
        Foreground="#EAF0FF">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Shutter" FontSize="24" FontWeight="SemiBold" Foreground="#F6F8FF"/>
        <TextBlock Grid.Row="1"
                   Text="Configure your recording shortcut and preferred input device."
                   Margin="0,4,0,18"
                   Foreground="#A4B4D3"/>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Global Hotkey" Style="{StaticResource SectionTitleStyle}"/>
                <WrapPanel Margin="0,10,0,0" ItemWidth="90">
                    <CheckBox x:Name="WinCheck" Content="Win" Margin="0,0,10,8"/>
                    <CheckBox x:Name="CtrlCheck" Content="Ctrl" Margin="0,0,10,8"/>
                    <CheckBox x:Name="AltCheck" Content="Alt" Margin="0,0,10,8"/>
                    <CheckBox x:Name="ShiftCheck" Content="Shift" Margin="0,0,10,8"/>
                    <ComboBox x:Name="KeyCombo" Width="130" Margin="0,0,0,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Input Device" Style="{StaticResource SectionTitleStyle}"/>
                <ComboBox x:Name="DeviceCombo" Margin="0,10,0,0" DisplayMemberPath="Name" SelectedValuePath="Id"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4"
                   Margin="2,14,0,0"
                   VerticalAlignment="Top"
                   Foreground="#7F92B8"
                   Text="Tip: Use modifiers + a letter key to avoid conflicts. Ctrl+Alt+Shift chords may conflict with NVDA/JAWS shortcuts."/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="CancelButton" Style="{StaticResource SecondaryButtonStyle}" Content="Cancel" Width="100" Margin="0,0,10,0" Click="OnCancel"/>
            <Button x:Name="SaveButton" Style="{StaticResource PrimaryButtonStyle}" Content="Save" Width="100" Click="OnSave"/>
        </StackPanel>
    </Grid>
</Window>
