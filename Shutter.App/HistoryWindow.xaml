<Window x:Class="Shutter.App.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recording History" Height="400" Width="600"
        WindowStyle="ToolWindow" Background="#1E1E1E" Foreground="White">
    <Grid>
        <ListView x:Name="HistoryList" Background="Transparent" Foreground="White" BorderThickness="0"
                  MouseDoubleClick="HistoryList_MouseDoubleClick"
                  SelectionChanged="HistoryList_SelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="5,2" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Foreground" Value="White" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Recorded" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠" Foreground="Yellow" Margin="0,0,5,0" Visibility="{Binding SilenceVisibility}" ToolTip="Likely silent recording" />
                                    <TextBlock Text="❌" Foreground="Red" Margin="0,0,5,0" Visibility="{Binding MissingVisibility}" ToolTip="File is missing" />
                                    <TextBlock Text="{Binding FriendlyTimestamp}" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Duration" Width="80" DisplayMemberBinding="{Binding FormattedDuration}" />
                    <GridViewColumn Header="Size" Width="80" DisplayMemberBinding="{Binding FormattedSize}" />
                    <GridViewColumn Header="Path" Width="280" DisplayMemberBinding="{Binding TruncatedPath}" />
                </GridView>
            </ListView.View>
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy Path" Click="CopyPath_Click" />
                    <MenuItem Header="Open File" Click="OpenFile_Click" />
                    <MenuItem Header="Open in Explorer" Click="OpenExplorer_Click" />
                    <Separator />
                    <MenuItem Header="Delete" Click="Delete_Click" />
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>
    </Grid>
</Window>
