<Window x:Class="Shutter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shutter Settings" Height="330" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Global Hotkey" FontWeight="SemiBold"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
            <CheckBox x:Name="WinCheck" Content="Win" Margin="0,0,12,0"/>
            <CheckBox x:Name="CtrlCheck" Content="Ctrl" Margin="0,0,12,0"/>
            <CheckBox x:Name="AltCheck" Content="Alt" Margin="0,0,12,0"/>
            <CheckBox x:Name="ShiftCheck" Content="Shift" Margin="0,0,12,0"/>
            <ComboBox x:Name="KeyCombo" Width="120"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Input Device" FontWeight="SemiBold" Margin="0,18,0,6"/>
        <ComboBox Grid.Row="3" x:Name="DeviceCombo" DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Width="86" Margin="0,0,8,0" Click="OnCancel"/>
            <Button x:Name="SaveButton" Content="Save" Width="86" Click="OnSave"/>
        </StackPanel>
    </Grid>
</Window>
